{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/cron.js": {
      "maxDuration": 300
    },
    "api/manual.js": {
      "maxDuration": 300
    },
    "api/status.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "* * * * *"
    }
  ]
}
